<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0" />
  <title>Krunker-lite v1.4 | AI・數據・成就・排行榜</title>
  <style>
    :root{--bg:#16213e;--panel:rgba(26,26,46,0.95);--acc:#4ecca3;--txt:#fff;--brd:#4ecca3;--danger:#ff6b6b;--warn:#f9c74f}
    body.dark{--bg:#0d0d0d;--panel:rgba(13,13,13,0.96);--acc:#888;--txt:#ccc;--brd:#555}
    body.day{--bg:#eef2f6;--panel:rgba(255,255,255,0.96);--acc:#2c3e50;--txt:#111;--brd:#2c3e50}
    *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
    html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);font-family:system-ui,sans-serif;touch-action:none;user-select:none;color:var(--txt)}
    canvas{display:block;width:100vw;height:100vh;image-rendering:pixelated}
    .ui{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
    .scr{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--panel);padding:1.5rem;border-radius:16px;text-align:center;pointer-events:auto;border:3px solid var(--brd);max-width:95vw;box-shadow:0 0 30px rgba(0,0,0,0.4);max-height:90vh;overflow-y:auto}
    .scr.h{display:none!important}
    h1,h2{color:var(--acc);margin-bottom:0.5rem}
    .hint{margin:0.8rem 0;padding:0.8rem;background:rgba(128,128,128,0.15);border-radius:10px;font-size:0.85rem;text-align:left;line-height:1.5;border-left:4px solid var(--acc)}
    .btn{display:inline-block;margin:0.4rem 0.2rem;padding:0.8rem 1.8rem;background:linear-gradient(135deg,var(--acc),color-mix(in srgb,var(--acc) 70%,#000));color:var(--txt);font-weight:600;border:none;border-radius:10px;cursor:pointer;font-size:1rem;transition:transform .1s}
    .btn:hover{transform:translateY(-2px)} .btn:active{transform:scale(.97)} .btn.sec{background:#6c757d}
    #hud{position:absolute;top:0;left:0;width:100%;padding:.7rem 1rem;display:flex;justify-content:space-between;pointer-events:none;z-index:50}
    .box{background:var(--panel);padding:.4rem .8rem;border-radius:8px;border:2px solid var(--brd);min-width:100px}
    .lbl{font-size:.75rem;opacity:.7} .val{font-size:1.2rem;color:var(--acc);font-weight:bold}
    #hpBar{width:120px;height:12px;background:rgba(0,0,0,.3);border-radius:6px;overflow:hidden;margin-top:4px;border:1px solid #555}
    #hpFill{height:100%;width:100%;background:linear-gradient(90deg,var(--acc),#3aa885);transition:width .15s}
    #hpFill.low{background:linear-gradient(90deg,var(--danger),#e53935)}
    #wbar{position:absolute;bottom:15px;left:50%;transform:translateX(-50%);display:flex;gap:8px;pointer-events:auto;z-index:60}
    .wb{width:46px;height:46px;border-radius:10px;background:var(--panel);border:2px solid var(--brd);color:var(--txt);font-size:1.3rem;cursor:pointer;display:flex;align-items:center;justify-content:center}
    .wb.act{background:var(--acc);color:var(--bg);border-color:#fff;transform:scale(1.1)}
    #tc{position:absolute;bottom:10px;width:100%;height:110px;display:none;pointer-events:none;z-index:55}
    .jz{position:absolute;width:100px;height:100px;border-radius:50%;background:rgba(128,128,128,.15);border:2px dashed rgba(128,128,128,.4);pointer-events:auto;display:flex;align-items:center;justify-content:center}
    #mz{left:20px} #sz{right:20px}
    .jk{width:40px;height:40px;background:var(--acc);border-radius:50%;border:3px solid #fff}
    .jz.act .jk{transform:scale(.85)} #sz.act{background:rgba(255,107,107,.25)}
    .top-btn{position:absolute;top:8px;width:34px;height:34px;border-radius:50%;background:var(--panel);border:2px solid var(--brd);color:var(--txt);cursor:pointer;font-size:1rem;z-index:70;display:flex;align-items:center;justify-content:center}
    #abtn{right:8px} #tbtn{right:48px} .muted{color:var(--danger)!important;border-color:var(--danger)!important}
    #achPopup{position:fixed;top:80px;right:20px;background:var(--panel);border:2px solid var(--acc);padding:1rem;border-radius:12px;z-index:100;opacity:0;transform:translateY(-20px);transition:.3s;pointer-events:auto}
    #achPopup.show{opacity:1;transform:translateY(0)}
    .stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:1rem 0;font-size:.9rem}
    .stat-row{background:rgba(128,128,128,.1);padding:6px 10px;border-radius:6px;display:flex;justify-content:space-between}
    .badge{display:inline-block;padding:4px 10px;margin:4px;background:#2a3a4a;border-radius:20px;font-size:.8rem;border:1px solid var(--acc)}
    .badge.locked{opacity:.4;filter:grayscale(1)}
    table{width:100%;border-collapse:collapse;margin:1rem 0;font-size:.85rem}
    th,td{padding:8px;border-bottom:1px solid rgba(255,255,255,.1);text-align:left}
    tr:nth-child(even){background:rgba(255,255,255,.05)}
    .tabs{display:flex;gap:8px;margin-bottom:10px;justify-content:center}
    .tab{padding:6px 14px;background:rgba(255,255,255,.1);border-radius:20px;cursor:pointer;font-size:.9rem}
    .tab.act{background:var(--acc);color:var(--bg)}
    @media(max-width:768px){
      h1{font-size:1.5rem} .scr{padding:1rem} .btn{padding:.7rem 1.4rem}
      #tc{display:flex} #wbar{bottom:130px} .box{min-width:85px}
    }
  </style>
</head>
<body class="neon">
  <canvas id="c"></canvas>
  <div class="ui">
    <button id="abtn" class="top-btn">🔊</button>
    <button id="tbtn" class="top-btn">🌙</button>
    <div id="achPopup"><div style="font-size:1.2rem">🏆</div><div id="achName" style="font-weight:bold;margin-top:4px"></div></div>
    
    <div id="start" class="scr">
      <h1>🎯 Krunker-lite</h1>
      <p style="opacity:.8;margin:.5rem 0;font-size:.85rem">v1.4 迭代5：AI FSM・數據・成就・排行榜</p>
      <div class="hint">💻 WASD移動 / 滑鼠射擊 / Q切槍 / R主題<br>📱 左搖桿 / 右射擊 / 底欄切槍</div>
      <p style="font-size:.8rem;margin:.5rem 0">🏆 歷史最高: <span id="hs">0</span> | 🎖️ 已解成就: <span id="ac">0</span>/5</p>
      <button class="btn" id="sbtn">▶️ 開始</button>
    </div>

    <div id="end" class="scr h">
      <h2>💥 任務結束</h2>
      <div class="tabs">
        <div class="tab act" data-t="stats">📊 數據</div>
        <div class="tab" data-t="ach">🏆 成就</div>
        <div class="tab" data-t="lb">🌐 排行榜</div>
      </div>
      <div id="t-stats">
        <div class="stat-grid" id="sg"></div>
        <button class="btn" id="rbtn1">🔄 重玩</button>
      </div>
      <div id="t-ach" class="h"><div id="al"></div></div>
      <div id="t-lb" class="h">
        <table id="lbt"><thead><tr><th>#</th><th>玩家</th><th>分數</th></tr></thead><tbody></tbody></table>
        <button class="btn" id="rbtn2">🔄 重玩</button>
      </div>
    </div>

    <div id="hud" class="h">
      <div><div class="box"><div class="lbl">分數</div><div class="val" id="sc">0</div></div>
      <div class="box" style="margin-top:4px"><div class="lbl">時間</div><div class="val" id="tm">60s</div></div></div>
      <div style="text-align:right"><div class="box"><div class="lbl">HP</div><div id="hpBar"><div id="hpFill"></div></div></div></div>
    </div>
    <div id="wbar" class="h">
      <button class="wb act" data-w="pistol">🔫</button>
      <button class="wb" data-w="smg">🔫💨</button>
      <button class="wb" data-w="shotgun">💥</button>
    </div>
    <div id="tc">
      <div id="mz" class="jz"><div class="jk"></div></div>
      <div id="sz" class="jz"><div class="jk"></div></div>
    </div>
  </div>

<script>
/** Krunker-lite v1.4 | Iter5: AI FSM + Stats + Achievements + LB + Storage v2 */
const CFG = {
  P: {spd:4.5,r:16,mhp:100},
  W: {pistol:{rate:180,dmg:15,sp:0,auto:false,c:1}, smg:{rate:60,dmg:8,sp:.1,auto:true,c:1}, shotgun:{rate:600,dmg:22,sp:.18,auto:false,c:5}},
  E: {r:18,hp:30,spd:1.8,dmg:8,si:1500,md:220,drop:.15, detectR:250},
  PU: {r:20,max:3,si:20000,types:{hp:{sym:'+',col:'#2ecc71',eff:'heal',v:30},fr:{sym:'⚡',col:'#3498db',eff:'fr',v:2,d:10000},sh:{sym:'🛡️',col:'#9b59b6',eff:'sh',v:1,d:5000}}},
  AI: {patrolR:150, stuckTime:1500, fleeHp:.3},
  TH: {neon:{bg:'#16213e',acc:'#4ecca3',txt:'#fff',pan:'rgba(26,26,46,0.95)'},dark:{bg:'#0d0d0d',acc:'#888',txt:'#ccc',pan:'rgba(13,13,13,0.96)'},day:{bg:'#eef2f6',acc:'#2c3e50',txt:'#111',pan:'rgba(255,255,255,0.96)'}}
};
const ACH_LIST = [
  {id:'fb',name:'初出茅廬',check:s=>s.kills>=1},
  {id:'hs',name:'連擊大師',check:s=>s.maxStreak>=5},
  {id:'ac',name:'神槍手',check:s=>(s.shotsFired>0?(s.shotsHit/s.shotsFired)*100>=75:false)},
  {id:'sw',name:'鋼鐵意志',check:s=>s.damageTaken<=20 && s.timeSurvived>=10},
  {id:'sr',name:'生存者',check:s=>s.timeSurvived>=60}
];

// 存檔管理 (v2 遷移)
const DB = {
  d:{h:0,k:0,v:.7,t:'neon',unlocked:[],ver:2,lb:[]},
  load(){try{let s=JSON.parse(localStorage.getItem('kr_v14'));if(!s)throw 1;if(s.ver<2)s={...{h:0,k:0,v:.7,t:'neon',unlocked:[],ver:1,lb:[]},...s,ver:2};return this.d={...this.d,...s}}catch(e){}},
  save(){try{localStorage.setItem('kr_v14',JSON.stringify(this.d))}catch(e){}},
  unlock(id){if(!this.d.unlocked.includes(id)){this.d.unlocked.push(id);this.save();return true}return false}
};
DB.load();

const Theme = {cur:'neon',apply(n){this.cur=n;DB.d.t=n;DB.save();const c=CFG.TH[n];document.body.className=n;document.documentElement.style.setProperty('--bg',c.bg);document.documentElement.style.setProperty('--acc',c.acc);document.documentElement.style.setProperty('--txt',c.txt);document.documentElement.style.setProperty('--panel',c.pan);}};
Theme.apply(DB.d.t);

// 音效
const Audio = {ctx:null,on:true,
  init(){if(!this.ctx)this.ctx=new(window.AudioContext||window.webkitAudioContext)();if(this.ctx.state==='suspended')this.ctx.resume();},
  play(t){if(!this.on||!this.ctx)return;const n=this.ctx.currentTime,g=this.ctx.createGain();g.gain.value=DB.d.v;g.connect(this.ctx.destination);
    if(t==='s'){const o=this.ctx.createOscillator();o.type='square';o.frequency.value=400;g.gain.exponentialRampToValueAtTime(.01,n+.08);o.connect(g);o.start();o.stop(n+.1)}
    else if(t==='h'){const b=this.ctx.createBuffer(1,this.ctx.sampleRate*.1,this.ctx.sampleRate),d=b.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=Math.random()*2-1;const s=this.ctx.createBufferSource();s.buffer=b;const f=this.ctx.createBiquadFilter();f.type='lowpass';f.frequency.value=900;s.connect(f).connect(g);s.start()}
    else if(t==='x'){const o=this.ctx.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(200,n);o.frequency.exponentialRampToValueAtTime(50,n+.25);g.gain.exponentialRampToValueAtTime(.01,n+.25);o.connect(g);o.start();o.stop(n+.3)}
    else if(t==='p'){[880,1100,1320].forEach((f,i)=>setTimeout(()=>{const o=this.ctx.createOscillator();const g2=this.ctx.createGain();g2.gain.value=DB.d.v;o.frequency.value=f;o.connect(g2).connect(this.ctx.destination);o.start();o.stop(this.ctx.currentTime+.1)},i*50))}
  }
};

// 輸入
const In = {k:{},m:{x:0,y:0,d:false},t:{m:{a:false,x:0,y:0,sx:0,sy:0},s:{a:false}},
  init(cv){
    window.addEventListener('keydown',e=>{this.k[e.key.toLowerCase()]=true;if(e.key===' ')Game.p?.shoot();if(e.key==='q'||e.key==='ArrowLeft')Game.cycleW(-1);if(e.key==='e'||e.key==='Tab'||e.key==='ArrowRight')Game.cycleW(1)});
    window.addEventListener('keyup',e=>this.k[e.key.toLowerCase()]=false);
    const um=e=>{const r=cv.getBoundingClientRect();this.m.x=e.clientX-r.left;this.m.y=e.clientY-r.top};
    cv.addEventListener('mousemove',um);cv.addEventListener('mousedown',e=>{if(e.button===0){um(e);this.m.d=true;Game.p?.shoot()}});cv.addEventListener('mouseup',()=>this.m.d=false);
    const mz=document.getElementById('mz'),sz=document.getElementById('sz');
    mz.addEventListener('touchstart',e=>{e.preventDefault();const t=e.touches[0],r=mz.getBoundingClientRect();this.t.m={a:true,sx:r.left+r.width/2,sy:r.top+r.height/2,x:t.clientX,y:t.clientY};mz.classList.add('active')},{passive:false});
    mz.addEventListener('touchmove',e=>{if(this.t.m.a){e.preventDefault();const t=e.touches[0];this.t.m.x=t.clientX;this.t.m.y=t.clientY}},{passive:false});
    const em=e=>{e?.preventDefault();this.t.m.a=false;mz?.classList.remove('active')};mz.addEventListener('touchend',em);mz.addEventListener('touchcancel',em);
    sz.addEventListener('touchstart',e=>{e.preventDefault();this.t.s.a=true;sz.classList.add('active');Game.p?.shoot()},{passive:false});
    sz.addEventListener('touchend',()=>{this.t.s.a=false;sz.classList.remove('active')});
    document.querySelectorAll('.wb').forEach(b=>b.addEventListener('click',()=>Game.setW(b.dataset.w)));
    document.getElementById('abtn').onclick=()=>{Audio.init();Audio.on=!Audio.on;document.getElementById('abtn').textContent=Audio.on?'🔊':'🔇';document.getElementById('abtn').classList.toggle('muted',!Audio.on)};
    document.getElementById('tbtn').onclick=()=>Theme.apply(Theme.cur==='neon'?'dark':Theme.cur==='dark'?'day':'neon');
    document.querySelectorAll('.tab').forEach(t=>t.addEventListener('click',()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.toggle('act',x.dataset.t===t.dataset.t));document.getElementById('t-stats').classList.toggle('h',t.dataset.t!=='stats');document.getElementById('t-ach').classList.toggle('h',t.dataset.t!=='ach');document.getElementById('t-lb').classList.toggle('h',t.dataset.t!=='lb')}));
    document.getElementById('rbtn1').onclick=document.getElementById('rbtn2').onclick=()=>Game.start();
    document.getElementById('mbtn').onclick=()=>{Game.state='menu';document.getElementById('end').classList.add('h');document.getElementById('start').classList.remove('h')};
    const mb=document.getElementById('mbtn')||document.createElement('button');
    if(!document.getElementById('mbtn')){mb.textContent='🏠';mb.className='btn sec';document.getElementById('end').prepend(mb)}
  },
  vec(){let dx=0,dy=0;if(this.k.w||this.k.arrowup)dy-=1;if(this.k.s||this.k.arrowdown)dy+=1;if(this.k.a||this.k.arrowleft)dx-=1;if(this.k.d||this.k.arrowright)dx+=1;
    if(this.t.m.a){dx+=(this.t.m.x-this.t.m.sx)/40;dy+=(this.t.m.y-this.t.m.sy)/40}
    if(dx||dy){const l=Math.hypot(dx,dy);if(l>1){dx/=l;dy/=l}return{x:dx,y:dy}}return{x:0,y:0}}
};

// 離屏快取
const Spr={p:null,e:null,init(){this.p=this._d('#4ecca3');this.e=this._d('#ff6b6b')},_d(c){const v=new OffscreenCanvas(32,32),x=v.getContext('2d');x.imageSmoothingEnabled=false;['..##..','.#**#.','#*##*#','*####*','#****#','*##**#','.**..#','.##...'].forEach((r,y)=>{for(let i=0;i<r.length;i++){const ch=r[i];x.fillStyle=ch==='#'?'#111':ch==='*'?c:'rgba(100,100,100,0.5)';x.fillRect(i*2,y*2,2,2)}});return v}};

// 物件
class Pt{a=false;x=0;y=0;vx=0;vy=0;l=400;ml=400;r=2;c='#fff';reset(x,y,c){this.x=x;this.y=y;const a=Math.random()*Math.PI*2,s=Math.random()*2.5+1;this.vx=Math.cos(a)*s;this.vy=Math.sin(a)*s;this.l=400;this.ml=this.l;this.r=Math.random()*2.5+1.5;this.c=c;this.a=true}u(dt){this.x+=this.vx;this.y+=this.vy;this.l-=dt;this.r*=.96;return this.l<=0||this.r<.5}d(ctx){if(!this.a)return;ctx.globalAlpha=this.l/this.ml;ctx.fillStyle=this.c;ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fill();ctx.globalAlpha=1}}
class Bl{a=false;x=0;y=0;vx=0;vy=0;dmg=15;r=4;reset(x,y,ang,w){this.x=x;this.y=y;this.dmg=CFG.W[w].dmg;const sp=(Math.random()-.5)*CFG.W[w].sp*2;this.vx=Math.cos(ang+sp)*10;this.vy=Math.sin(ang+sp)*10;this.a=true}u(){this.x+=this.vx;this.y+=this.vy;if(this.x<-20||this.x>G.cv.width+20||this.y<-20||this.y>G.cv.height+20)this.a=false;for(const o of G.obs)if(this.x>o.x&&this.x<o.x+o.w&&this.y>o.y&&this.y<o.y+o.h){this.a=false;for(let i=0;i<2;i++)G.spawnPt(this.x,this.y,'#aaa')}}d(ctx){if(!this.a)return;ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fill()}}
class En{a=false;x=0;y=0;r=18;hp=30;mhp=30;spd=1.8;tgt=null;cd=0;state='PATROL';ptX=0;ptY=0;stuckT=0;
  reset(x,y,t){this.x=x;this.y=y;this.hp=30;this.mhp=30;this.tgt=t;this.cd=0;this.a=true;this.state='PATROL';this.stuckT=0;this.pickPatrol()}
  pickPatrol(){const cv=G.cv;this.ptX=100+Math.random()*(cv.width-200);this.ptY=100+Math.random()*(cv.height-200)}
  u(dt){if(!this.tgt||!this.a)return;const dx=this.tgt.x-this.x,dy=this.tgt.y-this.y,dist=Math.hypot(dx,dy);
    // 狀態切換
    if(this.hp/this.mhp<=CFG.AI.fleeHp) this.state='FLEE';
    else if(dist<CFG.E.detectR) this.state='CHASE';
    else if(this.state!=='PATROL') this.state='PATROL';
    
    let vx=0,vy=0;
    if(this.state==='CHASE'){vx=dx;vy=dy;this.spd=1.8*1.2}
    else if(this.state==='FLEE'){vx=-dx;vy=-dy;this.spd=1.8*1.1}
    else{const pdx=this.ptX-this.x,pdy=this.ptY-this.y;if(Math.hypot(pdx,pdy)<20){this.pickPatrol()}vx=pdx;vy=pdy;this.spd=1.8}
    const len=Math.hypot(vx,vy);if(len>0){vx/=len;vy/=len;this.x+=vx*this.spd;this.y+=vy*this.spd}
    // 卡牆檢測
    const beforeDist=Math.hypot(this.ptX-this.x,this.ptY-this.y);if(this.state==='PATROL'&&Math.hypot(vx,vy)>0&&beforeDist>50&&Math.hypot(this.tgt.x-this.x,this.tgt.y-this.y)>CFG.E.detectR){this.stuckT+=dt;if(this.stuckT>CFG.AI.stuckTime){this.x+=(Math.random()-.5)*15;this.y+=(Math.random()-.5)*15;this.stuckT=0}}else this.stuckT=0;
    G.push(this);if(this.cd>0)this.cd-=dt}
  d(ctx){if(!this.a)return;ctx.drawImage(Spr.e,this.x-16,this.y-16);ctx.strokeStyle=this.state==='CHASE'?'#f00':this.state==='FLEE'?'#9b59b6':'#fff';ctx.lineWidth=2;ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.stroke();const p=this.hp/this.mhp;ctx.fillStyle='#333';ctx.fillRect(this.x-18,this.y-this.r-10,36,5);ctx.fillStyle=p>.5?'#4ecca3':p>.25?'#f9c74f':'#ff6b6b';ctx.fillRect(this.x-18,this.y-this.r-10,36*p,5)}
  hit(d){this.hp-=d;return this.hp<=0}}
class Pu{a=false;x=0;y=0;tp='hp';cfg={};col=false;pulse=0;rot=0;reset(x,y,tp){this.x=x;this.y=y;this.tp=tp;this.cfg=CFG.PU.types[tp];this.a=true;this.col=false}u(){this.pulse=(Math.sin(Date.now()/200)+1)*.15+1;this.rot+=.03}d(ctx){if(!this.a||this.col)return;ctx.save();ctx.translate(this.x,this.y);ctx.rotate(this.rot);const s=18*this.pulse;ctx.strokeStyle=this.cfg.col;ctx.lineWidth=2;ctx.globalAlpha=.7;ctx.beginPath();ctx.arc(0,0,s+4,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1;ctx.fillStyle=this.cfg.col;ctx.beginPath();ctx.arc(0,0,s,0,Math.PI*2);ctx.fill();ctx.fillStyle='#fff';ctx.font='bold 14px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(this.cfg.sym,0,1);ctx.restore()}}
class Pl{x=0;y=0;r=16;spd=4.5;hp=100;mhp=100;a=0;wep='pistol';lf=0;fl=0;buffs={};init(x,y){this.x=x;this.y=y;this.hp=100;this.a=0;this.wep='pistol';this.lf=0;this.fl=0;this.buffs={}}u(dt){const m=In.vec();if(m.x||m.y){this.x+=m.x*this.spd;this.y+=m.y*this.spd;this.a=Math.atan2(m.y,m.x)}if(In.m.x&&In.m.y)this.a=Math.atan2(In.m.y-this.y,In.m.x-this.x);G.push(this);if(this.fl>0)this.fl-=dt;const now=Date.now();for(const k in this.buffs)if(this.buffs[k].e<now)delete this.buffs[k]}dmg(a){if(this.buffs.sh)return false;this.hp-=a;this.fl=150;return this.hp<=0}apply(tp){const c=CFG.PU.types[tp];if(c.eff==='heal')this.hp=Math.min(this.mhp,this.hp+c.v);else this.buffs[c.eff]={e:Date.now()+(c.d||0)};Audio.play('p')}shoot(){const now=Date.now(),w=CFG.W[this.wep];if(now-this.lf<w.rate)return;this.lf=now;Audio.play('s');G.stats.shotsFired++;const bx=this.x+Math.cos(this.a)*(this.r+5),by=this.y+Math.sin(this.a)*(this.r+5);for(let i=0;i<w.c;i++){const b=G.bls.find(x=>!x.a);if(b){b.reset(bx,by,this.a,this.wep)}}}d(ctx){ctx.save();ctx.translate(this.x,this.y);ctx.rotate(this.a);if(this.fl>0&&Math.floor(this.fl/50)%2===0){ctx.globalAlpha=.6;ctx.fillStyle='#ff6b6b'}else ctx.fillStyle=CFG.TH[Theme.cur].acc;ctx.drawImage(Spr.p,-16,-16);ctx.restore();ctx.globalAlpha=1;if(this.buffs.sh){ctx.strokeStyle='rgba(155,89,182,0.8)';ctx.lineWidth=3;ctx.globalAlpha=.6+Math.sin(Date.now()/100)*.2;ctx.beginPath();ctx.arc(this.x,this.y,this.r+8,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1}}}
class Ob{x=0;y=0;w=0;h=0;constructor(x,y,w,h){this.x=x;this.y=y;this.w=w;this.h=h}d(ctx){ctx.fillStyle='#3a3a4a';ctx.fillRect(this.x,this.y,this.w,this.h);ctx.strokeStyle='#666';ctx.lineWidth=2;ctx.strokeRect(this.x,this.y,this.w,this.h)}}

// 主遊戲
const G={
  cv:null,ctx:null,state:'menu',p:null,obs:[],bls:[],pts:[],ens:[],pus:[],
  score:0,timeLeft:60,lastTime:0,spawnT:0,puT:0,
  stats:{kills:0,shotsFired:0,shotsHit:0,maxStreak:0,currentStreak:0,damageTaken:0,damageDealt:0,puCollected:0,timeSurvived:0},
  init(){
    this.cv=document.getElementById('c');this.ctx=this.cv.getContext('2d');this.resize();window.addEventListener('resize',()=>this.resize());
    Spr.init();In.init(this.cv);
    for(let i=0;i<40;i++)this.bls.push(new Bl);for(let i=0;i<180;i++)this.pts.push(new Pt);for(let i=0;i<25;i++)this.ens.push(new En);for(let i=0;i<8;i++)this.pus.push(new Pu);
    document.getElementById('hs').textContent=DB.d.h;document.getElementById('ac').textContent=DB.d.unlocked.length;
    this.lbGen();
    this.loop(0);
    document.getElementById('sbtn').onclick=()=>{Audio.init();this.start()};
  },
  resize(){this.cv.width=innerWidth;this.cv.height=innerHeight},
  lbGen(){
    if(!DB.d.lb||DB.d.lb.length===0){const names=['KrunkerBot','Shadow','Neo','Viper','Ghost','Ace','Frost','Blaze','Raven','Spark'];
      DB.d.lb=names.map((n,i)=>({name:n,score:50+Math.floor(Math.random()*350),date:'--'}));}
    const btns=[document.getElementById('rbtn1'),document.getElementById('rbtn2')];
    btns.forEach(b=>b.onclick=()=>this.start());
  },
  start(){
    this.state='play';this.p=new Pl;this.p.init(this.cv.width/2,this.cv.height/2);
    this.score=0;this.timeLeft=60;this.spawnT=0;this.puT=0;
    this.stats={kills:0,shotsFired:0,shotsHit:0,maxStreak:0,currentStreak:0,damageTaken:0,damageDealt:0,puCollected:0,timeSurvived:0};
    this.obs=[];for(let i=0;i<5;i++)this.spawnOb();
    document.getElementById('start').classList.add('h');document.getElementById('end').classList.add('h');document.getElementById('hud').classList.remove('h');document.getElementById('wbar').classList.remove('h');
    document.getElementById('tm').textContent='60s';this.updateUI();
    console.log('[Game] 迭代5啟動 | AI FSM 已載入');
  },
  spawnOb(){const w=40+Math.random()*60,h=40+Math.random()*60;let x=30+Math.random()*(this.cv.width-w-60),y=30+Math.random()*(this.cv.height-h-60);if(Math.hypot(x+w/2-this.p.x,y+h/2-this.p.y)>140&&!this.obs.some(o=>!(x+w<o.x||x>o.x+o.w||y+h<o.y||y>o.y+o.h)))this.obs.push(new Ob(x,y,w,h))},
  push(o){for(const r of this.obs){const cx=Math.max(r.x,Math.min(o.x,r.x+r.w)),cy=Math.max(r.y,Math.min(o.y,r.y+r.h)),dx=o.x-cx,dy=o.y-cy,d=Math.hypot(dx,dy);if(d<o.r){if(d===0)o.x=r.x-20;else{o.x+=dx/d*(o.r-d);o.y+=dy/d*(o.r-d)}}}},
  spawnPt(x,y,c){const p=this.pts.find(x=>!x.a);if(p)p.reset(x,y,c)},
  setW(w){if(!CFG.W[w])return;this.p.wep=w;document.querySelectorAll('.wb').forEach(b=>b.classList.toggle('act',b.dataset.w===w))},
  cycleW(d){const k=Object.keys(CFG.W);let i=k.indexOf(this.p.wep);this.setW(k[(i+d+k.length)%k.length])},
  over(){
    this.state='end';document.getElementById('hud').classList.add('h');document.getElementById('wbar').classList.add('h');document.getElementById('end').classList.remove('h');
    this.stats.timeSurvived=Math.floor(60-this.timeLeft||60);this.checkAch();
    const fs=document.getElementById('fs')||document.getElementById('sc');if(fs)fs.textContent=this.score;
    if(this.score>DB.d.h){DB.d.h=this.score;DB.save();document.getElementById('hs').textContent=this.score}
    DB.d.k+=this.stats.kills;DB.save();this.renderLB();this.renderStats();this.renderAch();Audio.play('x');
  },
  checkAch(){
    ACH_LIST.forEach(a=>{if(DB.unlock(a.id))this.showAch(a.name)});
    document.getElementById('ac').textContent=DB.d.unlocked.length;
  },
  showAch(n){const p=document.getElementById('achPopup');document.getElementById('achName').textContent=n;p.classList.add('show');setTimeout(()=>p.classList.remove('show'),3000)},
  renderLB(){
    DB.d.lb.push({name:'You',score:this.score,date:'Just Now'});
    DB.d.lb.sort((a,b)=>b.score-a.score);DB.d.lb=DB.d.lb.slice(0,10);DB.save();
    const tb=document.querySelector('#lbt tbody');tb.innerHTML='';
    DB.d.lb.forEach((r,i)=>{const tr=document.createElement('tr');tr.innerHTML=`<td>${i+1}</td><td style="color:${r.name==='You'?'var(--acc)':'#fff'}">${r.name}</td><td>${r.score}</td>`;tb.appendChild(tr)})
  },
  renderStats(){const s=this.stats,acc=s.shotsFired>0?Math.round(s.shotsHit/s.shotsFired*100):0;
    document.getElementById('sg').innerHTML=`<div class="stat-row"><span>擊殺</span><b>${s.kills}</b></div><div class="stat-row"><span>存活</span><b>${s.timeSurvived}s</b></div><div class="stat-row"><span>命中率</span><b>${acc}%</b></div><div class="stat-row"><span>最高連殺</span><b>${s.maxStreak}</b></div><div class="stat-row"><span>承受傷害</span><b>${s.damageTaken}</b></div><div class="stat-row"><span>道具拾取</span><b>${s.puCollected}</b></div>`},
  renderAch(){document.getElementById('al').innerHTML=ACH_LIST.map(a=>`<div class="badge ${DB.d.unlocked.includes(a.id)?'':'locked'}">${DB.d.unlocked.includes(a.id)?'🟢':'⚪'} ${a.name}</div>`).join('')},
  updateUI(){document.getElementById('sc').textContent=this.score;document.getElementById('tm').textContent=Math.ceil(this.timeLeft)+'s';const p=Math.max(0,this.p.hp/this.p.mhp*100);const f=document.getElementById('hpFill');f.style.width=p+'%';f.classList.toggle('low',p<30)},
  loop(ts){const dt=Math.min((ts-this.lastTime)/1000,.05);this.lastTime=ts;if(this.state==='play')this.update(dt*1000);this.draw();requestAnimationFrame(t=>this.loop(t))},
  update(dt){
    this.timeLeft-=dt/1000;if(this.timeLeft<=0){this.timeLeft=0;this.over();return}
    this.p.u(dt);if(CFG.W[this.p.wep].auto&&(In.m.d||In.t.s.a))this.p.shoot();
    this.bls.forEach(b=>{if(!b.a)return;b.u();if(!b.a)return;for(const e of this.ens){if(!e.a)continue;if(Math.hypot(b.x-e.x,b.y-e.y)<b.r+e.r){b.a=false;if(e.hit(b.dmg)){e.a=false;this.score+=10;this.stats.kills++;this.stats.shotsHit++;this.stats.currentStreak++;if(this.stats.currentStreak>this.stats.maxStreak)this.stats.maxStreak=this.stats.currentStreak;this.stats.damageDealt+=b.dmg;for(let i=0;i<6;i++)this.spawnPt(e.x,e.y,'#f00');Audio.play('x');if(Math.random()<CFG.E.drop){const p=this.pus.find(x=>!x.a);if(p)p.reset(e.x+(Math.random()-.5)*20,e.y+(Math.random()-.5)*20,Object.keys(CFG.PU.types)[Math.floor(Math.random()*3)])}}else{for(let i=0;i<2;i++)this.spawnPt(b.x,b.y,'#fff');this.stats.shotsHit++}}}});
    this.spawnT+=dt;if(this.spawnT>=CFG.E.si/Math.max(1,this.stats.kills*.05)){this.spawnT=0;const e=this.ens.find(x=>!x.a);if(e){let ex,ey;do{ex=Math.random()<.5?(Math.random()<.5?-20:this.cv.width+20):Math.random()*this.cv.width;ey=Math.random()<.5?(Math.random()<.5?-20:this.cv.height+20):Math.random()*this.cv.height}while(Math.hypot(ex-this.p.x,ey-this.p.y)<CFG.E.md);e.reset(ex,ey,this.p)}}
    this.ens.forEach(e=>{if(!e.a)return;e.u(dt);if(e.cd>0)e.cd-=dt;if(Math.hypot(e.x-this.p.x,e.y-this.p.y)<e.r+this.p.r&&e.cd<=0){if(this.p.dmg(CFG.E.dmg)){this.over();return}e.cd=500;this.stats.damageTaken+=CFG.E.dmg;this.stats.currentStreak=0}});
    this.puT+=dt;if(this.puT>=CFG.PU.si){this.puT=0;if(this.pus.filter(x=>x.a&&!x.col).length<CFG.PU.max){const p=this.pus.find(x=>!x.a);if(p)p.reset(50+Math.random()*(this.cv.width-100),50+Math.random()*(this.cv.height-100),Object.keys(CFG.PU.types)[Math.floor(Math.random()*3)])}}
    this.pus.forEach(w=>{if(!w.a||w.col)return;w.u();if(Math.hypot(w.x-this.p.x,w.y-this.p.y)<w.r*1.3+this.p.r){w.col=true;this.p.apply(w.tp);w.a=false;this.stats.puCollected++;for(let i=0;i<8;i++)this.spawnPt(w.x,w.y,w.cfg.col)}});
    this.pts.forEach(p=>{if(!p.a)return;if(p.u(dt))p.a=false});this.updateUI()},
  draw(){this.ctx.fillStyle=CFG.TH[Theme.cur].bg;this.ctx.fillRect(0,0,this.cv.width,this.cv.height);this.ctx.strokeStyle='rgba(128,128,128,.1)';this.ctx.lineWidth=1;for(let x=0;x<this.cv.width;x+=CFG.G){this.ctx.beginPath();this.ctx.moveTo(x,0);this.ctx.lineTo(x,this.cv.height);this.ctx.stroke()}for(let y=0;y<this.cv.height;y+=CFG.G){this.ctx.beginPath();this.ctx.moveTo(0,y);this.ctx.lineTo(this.cv.width,y);this.ctx.stroke()}
  if(this.state==='play'||this.state==='end'){this.obs.forEach(o=>o.d(this.ctx));this.pts.filter(x=>x.a).forEach(x=>x.d(this.ctx));this.bls.filter(x=>x.a).forEach(x=>x.d(this.ctx));this.ens.filter(x=>x.a).forEach(x=>x.d(this.ctx));this.pus.filter(x=>x.a&&!x.col).forEach(x=>x.d(this.ctx));if(this.p)this.p.d(this.ctx)}}
};
window.addEventListener('DOMContentLoaded',()=>G.init());
</script>
</body>
</html>